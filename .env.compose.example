# Minimal env for `docker compose up`.
# Copy to .env (which is gitignored) and fill in.

# --- Required for default cloud-LLM backend, OPTIONAL in BYOK mode ---
# Leave empty to deploy a public demo where every request must carry its own
# X-Anthropic-Key header (see "Bring Your Own Key" in the README). With no
# server-side key, you can't be billed for traffic that doesn't include a key.
ANTHROPIC_API_KEY=

# --- Optional overrides ---
# ANTHROPIC_MODEL=claude-haiku-4-5
# EXTRACTOR_BACKEND=cloud           # "cloud" (default) or "local" (needs --profile local-llm)
# EXTRACTOR_FALLBACK=none           # "none" | "local" | "cloud"
# INGESTION_REQUIRE_SIGNATURE=false # "true" rejects every webhook unless the source has a signing_secret AND the request is HMAC-signed
# INGESTION_RATE_LIMIT_PER_IP=10     # requests/min per client IP at the ingestion endpoint. 0 disables.
# INGESTION_RATE_LIMIT_PER_SOURCE=300 # requests/min per source_id. 0 disables.
# LOG_LEVEL=info                    # debug | info | warn | error
