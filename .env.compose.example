# Minimal env for `docker compose up`.
# Copy to .env (which is gitignored) and fill in.

# --- Required for default cloud-LLM backend ---
ANTHROPIC_API_KEY=

# --- Optional overrides ---
# ANTHROPIC_MODEL=claude-haiku-4-5
# EXTRACTOR_BACKEND=cloud           # "cloud" (default) or "local" (needs --profile local-llm)
# EXTRACTOR_FALLBACK=none           # "none" | "local" | "cloud"
# LOG_LEVEL=info                    # debug | info | warn | error
