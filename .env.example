# Ingestion
INGESTION_PORT=8080
INGESTION_MAX_BODY_BYTES=10485760   # 10MB max webhook body
INGESTION_REQUIRE_SIGNATURE=false   # set to "true" to reject unsigned webhooks even if the source has no secret

# Orchestrator
ORCHESTRATOR_WORKERS=10
ORCHESTRATOR_MAX_WORKERS=50
ORCHESTRATOR_QUEUE_SCALE_THRESHOLD=1000

# Delivery
DELIVERY_WORKERS=20
DELIVERY_MAX_WORKERS=100
DELIVERY_MAX_RETRIES=4

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ScyllaDB
SCYLLA_HOSTS=127.0.0.1
SCYLLA_KEYSPACE=webhookmind

# PostgreSQL
POSTGRES_DSN=postgres://webhookmind:password@127.0.0.1:5432/webhookmind?sslmode=disable

# Extractor Bridge
EXTRACTOR_BRIDGE_WORKERS=10
EXTRACTOR_BRIDGE_MAX_WORKERS=50
EXTRACTOR_BRIDGE_QUEUE_SCALE_THRESHOLD=1000

# MinIO
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=webhookmind
MINIO_SECRET_KEY=webhookmind123
MINIO_BUCKET=webhookmind-files
MINIO_USE_SSL=false

# Extraction backend: "local" (gRPC to C++ extractor container) or "cloud" (Anthropic API)
EXTRACTOR_BACKEND=local

# Optional fallback — if the primary backend fails, try this one. "none" disables fallback.
# Valid values: none | local | cloud. Must differ from EXTRACTOR_BACKEND.
EXTRACTOR_FALLBACK=none

# Local backend — C++ Extraction Engine via gRPC
EXTRACTOR_GRPC_ADDR=127.0.0.1:50051
EXTRACTOR_GRPC_TIMEOUT_SECONDS=120

# Cloud backend — Anthropic API (required only if EXTRACTOR_BACKEND=cloud)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
CLOUD_EXTRACTOR_TIMEOUT_SECONDS=60

# File Processing
FILE_MAX_SIZE_BYTES=52428800         # 50MB max file size
FILE_DOWNLOAD_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=info    # debug | info | warn | error
